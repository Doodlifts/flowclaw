# FlowClaw Configuration
# ======================
# Copy this file to .env and fill in your values.

# Flow Network — testnet or mainnet
FLOW_NETWORK=testnet
FLOW_ACCESS_NODE=https://rest-testnet.onflow.org
FLOW_ACCOUNT_ADDRESS=0xYOUR_FLOW_ADDRESS
FLOW_PRIVATE_KEY=YOUR_PRIVATE_KEY_HEX

# LLM Provider — venice, anthropic, openai, or ollama
VENICE_API_KEY=YOUR_VENICE_API_KEY
VENICE_BASE_URL=https://api.venice.ai/api/v1

# Fallback Providers (optional)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# Relay Settings
RELAY_POLL_INTERVAL=2
RELAY_MAX_RETRIES=3
RELAY_LOG_LEVEL=INFO

# CORS — comma-separated allowed origins
# For production: set to your Vercel domain, e.g. https://flowclaw.vercel.app
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Safety Limits
MAX_FLOW_TRANSFER=10.0
GAS_SPONSOR_DAILY_LIMIT=100

# Paths (optional)
FLOWCLAW_PROJECT_DIR=./
FLOWCLAW_ENCRYPTION_KEY=~/.flowclaw/encryption.key

# Emulator only
FLOW_EMULATOR_PRIVATE_KEY=
